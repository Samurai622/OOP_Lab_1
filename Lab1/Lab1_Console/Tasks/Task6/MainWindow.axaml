<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Task6.MainWindow"
        Title="Перевірка сортувань"
        Width="1000" Height="700"
        MinWidth="600" MinHeight="500"
        Background="#0F141E"
        Foreground="White"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#1A202C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2D3748"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </Window.Styles>

    <!-- Використовуємо Grid для того, щоб текстове поле розтягувалось -->
    <Grid RowDefinitions="Auto, *, Auto" Margin="20" MaxWidth="1200">
        
        <!-- ВЕРХНЯ ЧАСТИНА: Налаштування -->
        <StackPanel Grid.Row="0" Spacing="15" Margin="0,0,0,15">
            <StackPanel Spacing="5">
                <TextBlock Text="Перевірка сортувань" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Selection Sort / Shaker Sort (C#, Python, Java, C, C++)" 
                           Foreground="#A0AEC0" FontSize="14"/>
            </StackPanel>

            <Border Background="#1A202C" CornerRadius="8" Padding="15" BorderBrush="#2D3748" BorderThickness="1">
                <Grid ColumnDefinitions="*, *, Auto">
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Мова програмування" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5"/>
                        <ComboBox x:Name="LanguageCombo" SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem>C#</ComboBoxItem>
                            <ComboBoxItem>Python</ComboBoxItem>
                            <ComboBoxItem>Java</ComboBoxItem>
                            <ComboBoxItem>C</ComboBoxItem>
                            <ComboBoxItem>C++</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,10,0">
                        <TextBlock Text="Алгоритм" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5"/>
                        <ComboBox x:Name="AlgorithmCombo" SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem>Selection Sort</ComboBoxItem>
                            <ComboBoxItem>Shaker Sort</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="10,0,0,0">
                        <Button x:Name="BtnSelectFile" Content="Завантажити з файлу..." 
                                Click="BtnSelectFile_Click" Background="#2B6CB0" Foreground="White" Padding="15,8" CornerRadius="4"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <!-- СЕРЕДНЯ ЧАСТИНА: Поле для коду (розтягується на весь вільний простір) -->
        <Border Grid.Row="1" Background="#1A202C" CornerRadius="8" Padding="15" BorderBrush="#2D3748" BorderThickness="1">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                    <TextBlock Text="Код алгоритму" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Підставити приклад" Click="BtnExample_Click" 
                            Background="#4A5568" Foreground="White" CornerRadius="4" Padding="10,5"/>
                </Grid>
                
                <!-- TextBox розтягується автоматично завдяки Grid.Row="1" з висотою '*' -->
                <TextBox Grid.Row="1" x:Name="CodeInput" AcceptsReturn="True" TextWrapping="NoWrap" 
                         Background="#0B0E14" Foreground="#E2E8F0" BorderBrush="#2D3748" CornerRadius="4"
                         FontFamily="Consolas, Monospace" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

        <!-- НИЖНЯ ЧАСТИНА: Кнопка перевірки та результат -->
        <Border Grid.Row="2" Background="#1A202C" CornerRadius="8" Padding="15" BorderBrush="#2D3748" BorderThickness="1" Margin="0,15,0,0">
            <Grid ColumnDefinitions="Auto, *">
                <Button Grid.Column="0" Content="Перевірити код" Click="BtnCheck_Click" 
                        Background="#3182CE" Foreground="White" CornerRadius="4" Padding="20,10" FontSize="16" FontWeight="Bold" Margin="0,0,20,0"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Результат:" FontWeight="SemiBold" FontSize="14" Foreground="#A0AEC0"/>
                    <TextBlock x:Name="TxtResult" Text="Очікування перевірки..." Foreground="White" TextWrapping="Wrap" FontSize="16" FontWeight="Medium" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>