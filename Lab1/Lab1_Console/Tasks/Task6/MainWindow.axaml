<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        x:Class="Lab1_Task6.MainWindow"
        Title="Перевірка сортувань"
        Width="1000" Height="700"
        MinWidth="600" MinHeight="500"
        Background="#121212"
        Foreground="White"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="JetBrains Mono, monospace"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="FontFamily" Value="JetBrains Mono, Segoe UI, sans-serif"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
    </Window.Styles>

    <Grid RowDefinitions="Auto, *, Auto" Margin="20" MaxWidth="1200">
        
        <StackPanel Grid.Row="0" Spacing="15" Margin="0,0,0,15">
            <StackPanel Spacing="5">
                <TextBlock Text="Перевірка сортувань" FontFamily="JetBrains Mono, monospace" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Selection Sort / Shaker Sort (C#, Python, Java, C, C++)" 
                           Foreground="#AAAAAA" FontSize="14"/>
            </StackPanel>

            <Border Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#333333" BorderThickness="1">
                <Grid ColumnDefinitions="*, *, Auto">
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Мова програмування" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5"/>
                        <ComboBox x:Name="LanguageCombo" SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem>C#</ComboBoxItem>
                            <ComboBoxItem>Python</ComboBoxItem>
                            <ComboBoxItem>Java</ComboBoxItem>
                            <ComboBoxItem>C</ComboBoxItem>
                            <ComboBoxItem>C++</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,10,0">
                        <TextBlock Text="Алгоритм" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5"/>
                        <ComboBox x:Name="AlgorithmCombo" SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem>Selection Sort</ComboBoxItem>
                            <ComboBoxItem>Shaker Sort</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="10,0,0,0">
                        <Button x:Name="BtnSelectFile" Content="Завантажити з файлу..." 
                                Click="BtnSelectFile_Click" Background="#28A745" Foreground="White" Padding="15,8" CornerRadius="4"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#333333" BorderThickness="1">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                    <TextBlock Text="Код алгоритму" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Підставити приклад" Click="BtnExample_Click" 
                            Background="#444444" Foreground="White" CornerRadius="4" Padding="10,5"/>
                </Grid>
                
                <ae:TextEditor Grid.Row="1" x:Name="CodeInput"
               Background="#000000" Foreground="#FFFFFF" BorderBrush="#333333" CornerRadius="4"
               FontFamily="JetBrains Mono, monospace" 
               HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" 
               WordWrap="False"
               ShowLineNumbers="True" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#333333" BorderThickness="1" Margin="0,15,0,0">
            <Grid ColumnDefinitions="Auto, *">
                <Button Grid.Column="0" Content="Перевірити код" Click="BtnCheck_Click" 
                        Background="#28A745" Foreground="White" CornerRadius="4" Padding="20,10" FontSize="16" FontWeight="Bold" Margin="0,0,20,0"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Результат:" FontWeight="SemiBold" FontSize="14" Foreground="#AAAAAA"/>
                    <TextBlock x:Name="TxtResult" Text="Очікування перевірки..." Foreground="White" TextWrapping="Wrap" FontSize="16" FontWeight="Medium" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>